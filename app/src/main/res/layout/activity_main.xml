<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="60dp" />

            <!-- Circular Logo -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:padding="2dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#00FF41"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/appName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:text="Hacker Style Wallpaper"
                android:textColor="#00FF41"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <!-- Buttons List -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAbout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="220dp"
                android:layout_height="55dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"
                android:text="About"
                android:textColor="#00FF41"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconTint="#00FF41"
                app:strokeColor="#00FF41" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetting"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="220dp"
                android:layout_height="55dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"
                android:text="Setting"
                android:textColor="#00FF41"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconTint="#00FF41"
                app:strokeColor="#00FF41" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="220dp"
                android:layout_height="55dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"
                android:text="Share"
                android:textColor="#00FF41"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="#00FF41"
                app:strokeColor="#00FF41" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="220dp"
                android:layout_height="55dp"
                android:layout_marginBottom="30dp"
                android:fontFamily="monospace"
                android:text="@string/btn_check_update"
                android:textColor="#00FF41"
                app:icon="@android:drawable/stat_sys_download"
                app:iconTint="#00FF41"
                app:strokeColor="#00FF41" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetWallpaper"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:fontFamily="monospace"
                android:text="Activate Wallpaper"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#00FF41"
                app:cornerRadius="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvDevInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="monospace"
                android:text="@string/dev_info"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/version_text"
                android:textColor="#555555"
                android:textSize="10sp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
